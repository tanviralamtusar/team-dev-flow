rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /items/{itemId} {
      allow read, write: if true;
    }
    match /tags/{tagId} {
      allow read, write: if true;
    }
    match /assignees/{assigneeId} {
      allow read, write: if true;
    }
    match /columns/{columnId} {
      allow read, write: if true;
    }
    // General catch-all
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
